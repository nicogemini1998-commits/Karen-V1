# ============================================================
# Karen-V1 .env.example
# Copia a .env (gitignored) y rellena valores reales.
# ============================================================

# ─── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Memory Stack ──────────────────────────────────────────
# OBLIGATORIO: 20+ chars aleatorios. Genera con: openssl rand -base64 24.
# En prod usa Docker secrets.
NEO4J_PASSWORD=CAMBIAME-password-seguro
MEM0_USER_ID=your-user-id

# ─── GitHub (cuenta personal, NO empresa) ──────────────────
GITHUB_PAT=ghp_...
GITHUB_USERNAME=YOUR-GITHUB-USERNAME

# ─── OAuth (rellenar cuando autentiques cada MCP) ──────────
# Gmail personal
GMAIL_OAUTH_TOKEN=

# Google Calendar personal
GCAL_OAUTH_TOKEN=

# Outlook empresa (READ-ONLY)
OUTLOOK_OAUTH_TOKEN=

# Notion personal workspace
NOTION_TOKEN=
NOTION_WORKSPACE_URL=

# ─── Finanzas (opcional) ───────────────────────────────────
BIGDATA_COM_API_KEY=

# ─── Karen runtime ─────────────────────────────────────────
KAREN_ROOT=$HOME/karen-personal
KAREN_DEFAULT_TONE=friday
KAREN_LOG_LEVEL=info
