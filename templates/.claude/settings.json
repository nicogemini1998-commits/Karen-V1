{
  "_comentario": "Karen-V1 settings.json — instalado por install.sh. Hooks v2.0 enforcement activos.",
  "_version": "2.0",

  "model": "claude-opus-4-7",
  "language": "español",
  "theme": "light",

  "alwaysThinkingEnabled": true,

  "enabledPlugins": {
    "caveman@caveman": true,
    "claude-mem@thedotmack": true,
    "everything-claude-code@everything-claude-code": true,
    "firecrawl@claude-plugins-official": true,
    "brightdata-plugin@claude-plugins-official": true,
    "bigdata-com@claude-plugins-official": true,
    "circleback@claude-plugins-official": true
  },

  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm exec:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(pip3:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(docker-compose:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(echo:*)",
      "Bash(touch:*)",
      "Bash(date:*)",
      "mcp__hex-line__*",
      "mcp__memory__*",
      "mcp__firecrawl__*",
      "mcp__context7__*",
      "mcp__playwright__*",
      "mcp__github__*",
      "mcp__bigdata-com__*",
      "mcp__brightdata__*",
      "mcp__circleback__*"
    ]
  },

  "hooks": {
    "SessionStart": [
      {
        "command": "bash ~/.claude/karen/hooks/load-rules.sh",
        "timeout": 3000,
        "description": "Carga rules-learned.md + profile.json al boot"
      }
    ],
    "UserPromptSubmit": [
      {
        "command": "bash ~/.claude/karen/hooks/capture-correction.sh",
        "timeout": 2000,
        "description": "Detecta correcciones Nico, append a rules-learned"
      },
      {
        "command": "bash ~/.claude/karen/hooks/cliender-isolation-guard.sh",
        "timeout": 1000,
        "description": "Alerta si Cliender mencionado en cuenta personal"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|mcp__hex-line__write_file|mcp__hex-line__edit_file",
        "command": "bash ~/.claude/karen/hooks/raiz-limpia-guard.sh",
        "timeout": 1500,
        "description": "Bloquea archivos sueltos en raíz proyecto"
      },
      {
        "matcher": "Write|Edit|mcp__hex-line__write_file|mcp__hex-line__edit_file",
        "command": "bash ~/.claude/karen/hooks/secrets-guard.sh",
        "timeout": 1500,
        "description": "Bloquea escritura secretos fuera de .env"
      },
      {
        "matcher": "Read|Edit|Write|Glob|Grep|mcp__hex-line__*",
        "command": "bash ~/.claude/karen/hooks/domain-firewall.sh",
        "timeout": 1500,
        "description": "Aislamiento dominios por subagent"
      }
    ]
  }
}
