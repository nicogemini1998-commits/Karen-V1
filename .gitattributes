# Karen-V1 .gitattributes
# Preserva permisos executable + LF line endings cross-platform

# Scripts ejecutables
scripts/*.sh            text eol=lf
templates/.claude/hooks/*.sh   text eol=lf

# Markdown
*.md                    text eol=lf

# JSON
*.json                  text eol=lf

# YAML
*.yml                   text eol=lf
*.yaml                  text eol=lf

# Shell scripts ejecutables
*.sh                    text eol=lf

# Binarios (no aplica ahora pero por si)
*.png                   binary
*.jpg                   binary
*.pdf                   binary
